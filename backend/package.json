  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "husky": "^9.1.7",
    "shx": "^0.4.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/express": "^5.0.6",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5"
  }
