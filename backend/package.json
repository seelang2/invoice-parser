{
  "name": "@invoice-parser/backend",
  "version": "1.0.0",
  "description": "Web application that extracts structured data from invoice images/PDFs",
  "main": "index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm run clean && tsc && pnpm run copy-static",
    "clean": "shx rm -rf dist/",
    "copy-static": "shx cp -r src/public dist/",
    "prepare": "cd .. && husky backend/.husky",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
